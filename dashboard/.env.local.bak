# Local dashboard (npm run dev) → cloud ForgeOS backend on Cloud Run.
# Gitignored; not committed. Delete this file to go back to the local :5000 backend.

# HTTP API: next.config.js rewrites /api/* to this base. The browser stays
# same-origin (http://localhost:3000), so no CORS and auth.tsx's /api/me works.
FORGEOS_API_URL=https://forgeos-platform-api-meundhbn7a-ew.a.run.app

# Server-side (SSR) fetches go direct to the cloud (CORS doesn't apply server-side).
INTERNAL_API_URL=https://forgeos-platform-api-meundhbn7a-ew.a.run.app

# Live agent-status WebSocket. Next.js rewrites don't proxy WS upgrades, so the
# browser dials the cloud directly (wss://). Backend CORS already allows localhost:3000.
NEXT_PUBLIC_WS_URL=wss://forgeos-platform-api-meundhbn7a-ew.a.run.app

# The cloud backend enforces auth (unlike local --no-auth), so gate the UI behind
# /login. Set to 0 to browse the public endpoints (overview/health) without logging in.
NEXT_PUBLIC_REQUIRE_AUTH=1
