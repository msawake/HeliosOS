{
  "title": "ForgeOS — Platform Overview",
  "uid": "forgeos-overview",
  "tags": ["forgeos", "platform"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Agents Running",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "forgeos_agents_running",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Agents by Stack",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum by (stack) (forgeos_agents_total)",
          "refId": "A",
          "legendFormat": "{{stack}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pending HITL Approvals",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "forgeos_approvals_pending",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Scheduler Lag (seconds)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "forgeos_scheduler_lag_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Agent Invocations / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (stack) (rate(forgeos_agent_invoke_total[5m]))",
          "refId": "A",
          "legendFormat": "{{stack}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Agent Invocation Errors / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (stack) (rate(forgeos_agent_invoke_total{outcome=\"failed\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{stack}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "LLM Calls by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (provider) (rate(forgeos_llm_calls_total[5m]))",
          "refId": "A",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "LLM Tokens / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (provider, model) (rate(forgeos_llm_tokens_total[5m]))",
          "refId": "A",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "LLM Failovers",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (from_provider, to_provider) (increase(forgeos_llm_failover_total[5m]))",
          "refId": "A",
          "legendFormat": "{{from_provider}} → {{to_provider}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Tool Call P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(forgeos_tool_duration_seconds_bucket[5m])) by (le, tool_name))",
          "refId": "A",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11,
      "title": "Tenant Cost (MTD, top 10)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "topk(10, forgeos_tenant_cost_usd_month)",
          "refId": "A",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    }
  ]
}
