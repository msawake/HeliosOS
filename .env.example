# Copy to `.env` and fill in values. `.env` is gitignored — never commit real keys.
# Both the host-run platform and `docker compose up` read this file.
# Install OpenAI support: pip install -e ".[dev,openai]"
#
# https://console.anthropic.com/
# https://platform.openai.com/api-keys

# Leave empty for simulated LLM responses (no key required for local testing).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- docker compose overrides (optional) ---
# Postgres password — defaults to "forgeoslocal" for local dev.
# DB_PASSWORD=
# The docker stack disables API auth by default; set to empty to require tokens.
# FORGEOS_AUTH_DISABLED=

# --- host-run platform (optional) ---
# Flask API base URL for Next.js dev rewrites when bootstrap uses a non-default port (PORT / --port).
# FORGEOS_API_URL=http://localhost:5001
DATABASE_URL=
REDIS_URL=

# --- secret store (optional) ---
# Encryption key for the at-rest credential store (Postgres-backed). Stores
# secrets referenced from agent manifests as `api_key_ref: secret:<name>`
# (e.g. an LLM gateway / LiteLLM key). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a stable (insecure) dev key is derived — fine for local testing.
# FORGEOS_CRED_ENC_KEY=

# --- LLM gateway via env (optional, quick local alternative) ---
# Instead of storing a key in the secret store, a manifest can reference an
# env var directly: `api_key_ref: env:LITELLM_ALLYCODE_KEY`.
# LITELLM_ALLYCODE_KEY=
