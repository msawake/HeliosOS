# Copy to `.env` and fill in values. `.env` is gitignored — never commit real keys.
# Both the host-run platform and `docker compose up` read this file.
# Install OpenAI support: pip install -e ".[dev,openai]"
#
# https://console.anthropic.com/
# https://platform.openai.com/api-keys

# Leave empty for simulated LLM responses (no key required for local testing).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- docker compose overrides (optional) ---
# Postgres password — defaults to "forgeoslocal" for local dev.
# DB_PASSWORD=
# The docker stack disables API auth by default; set to empty to require tokens.
# FORGEOS_AUTH_DISABLED=

# --- host-run platform (optional) ---
# Flask API base URL for Next.js dev rewrites when bootstrap uses a non-default port (PORT / --port).
# FORGEOS_API_URL=http://localhost:5001
DATABASE_URL=
REDIS_URL=
