# Copy to `.env` and fill in values. `.env` is gitignored — never commit real keys.
# Install OpenAI support: pip install -e ".[dev,openai]"
#
# https://platform.openai.com/api-keys
# https://console.anthropic.com/

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Flask API base URL for Next.js dev rewrites when bootstrap uses a non-default port (PORT / --port).
# FORGEOS_API_URL=http://localhost:5001
DATABASE_URL=
REDIS_URL=
