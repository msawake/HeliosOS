        <mxCell id="a2bdg" value="🪪 Badge: &apos;scheduled-auditor&apos;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="70" y="280" width="240" height="50" as="geometry"/></mxCell>

