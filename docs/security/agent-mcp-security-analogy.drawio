        <mxCell id="a1t" value="Before — one master key, one sticky note" style="text;html=1;fontSize=22;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1000" height="34" as="geometry"/></mxCell>
        <mxCell id="a1s" value="An everyday picture of how sre-gcp-auditor works today on the platform" style="text;html=1;fontSize=13;align=left;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="40" y="56" width="1000" height="24" as="geometry"/></mxCell>

        <mxCell id="a1mail" value="📬 Outgoing email&lt;br&gt;&lt;br&gt;ALL agents send AS&lt;br&gt;antoni.bergas@…&lt;br&gt;&lt;br&gt;(no attribution — was it the auditor? the builder? You can't tell.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="180" width="240" height="200" as="geometry"/></mxCell>

        <mxCell id="a1bld" value="🏢  GCP project: admachina-atomic-test-84" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=center;verticalAlign=top;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="340" y="120" width="900" height="720" as="geometry"/></mxCell>

        <mxCell id="a1rA" value="🚪 Room A&lt;br&gt;IAM bindings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="370" y="170" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="a1rB" value="🚪 Room B&lt;br&gt;Cloud SQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="580" y="170" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="a1rC" value="🚪 Room C&lt;br&gt;Storage buckets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="790" y="170" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="a1rD" value="🚪 Room D&lt;br&gt;Cloud Run / secrets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="1000" y="170" width="180" height="90" as="geometry"/></mxCell>

        <mxCell id="a1off" value="Shared security office (the platform's ONE container)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="430" y="340" width="720" height="380" as="geometry"/></mxCell>
        <mxCell id="a1key" value="🔑  MASTER KEY — opens EVERY door&lt;br&gt;(Cloud Run runtime SA ≈ Editor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="460" y="380" width="660" height="70" as="geometry"/></mxCell>
        <mxCell id="a1ag" value="🤖 sre-gcp-auditor    🤖 marketing-agent    🤖 builder-agent&lt;br&gt;(all share the office and the key)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="460" y="470" width="660" height="60" as="geometry"/></mxCell>
        <mxCell id="a1note" value="📋  &apos;Only look. Don't touch. Project X only.&apos;&lt;br&gt;(this sticky note IS the entire safety rule)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="460" y="550" width="660" height="60" as="geometry"/></mxCell>
        <mxCell id="a1risk" value="⚠️  If the note is edited, ignored, or weird text slips into the agent's input — the master key still works." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="460" y="625" width="660" height="70" as="geometry"/></mxCell>

