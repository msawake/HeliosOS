        <mxCell id="a1e3" value="opens" style="endArrow=block;html=1;strokeColor=#b85450;strokeWidth=2;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="a1key" target="a1rC"><mxGeometry relative="1" as="geometry"/></mxCell>
