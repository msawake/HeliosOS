        <mxCell id="a2card" value="🪪 TEMP KEYCARD&lt;br&gt;read-only · projects A, B · expires in 15 min" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="380" y="370" width="280" height="80" as="geometry"/></mxCell>

