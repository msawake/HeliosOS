        <mxCell id="a2nox" value="…and any project NOT on the allowlist&lt;br&gt;is unreachable by design (no IAM grant exists)" style="text;html=1;align=center;fontSize=12;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="1010" y="510" width="360" height="60" as="geometry"/></mxCell>

