{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgeos.dev/a2h/v1/notification.json",
  "title": "A2H Notification",
  "description": "A one-way message from an agent to a human. No response expected.",
  "type": "object",
  "required": ["from", "to", "content"],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "a2h/v1"
    },
    "id": {
      "type": "string",
      "description": "Server-generated unique ID"
    },
    "type": {
      "type": "string",
      "const": "notification"
    },
    "from": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": { "type": "string" },
        "namespace": { "type": "string" },
        "participant_type": { "type": "string", "enum": ["agent"] }
      }
    },
    "to": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": { "type": "string" },
        "namespace": { "type": "string" },
        "participant_type": { "type": "string", "enum": ["human"] }
      }
    },
    "content": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": {
          "type": "string",
          "description": "The notification text"
        },
        "severity": {
          "type": "string",
          "enum": ["info", "success", "warning", "error"],
          "default": "info"
        },
        "context": {
          "type": "object",
          "description": "Structured data accompanying the notification",
          "additionalProperties": true
        }
      }
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "default": "low"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
