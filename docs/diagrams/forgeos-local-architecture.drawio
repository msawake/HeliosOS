<mxfile host="app.diagrams.net" type="device">
  <diagram name="ForgeOS local — CLI vs pods" id="forgeos-local">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== ZONES (drawn first = behind) ===================== -->
        <mxCell id="zHost" value="HOST machine (control plane — your laptop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="360" height="630" as="geometry" />
        </mxCell>
        <mxCell id="zCluster" value="kind cluster (Kubernetes) — deployed by Pulumi (target=local)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FB;strokeColor=#6A8FBF;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="70" width="600" height="630" as="geometry" />
        </mxCell>
        <mxCell id="nsLegal" value="namespace: legal" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DCEAF7;strokeColor=#6A8FBF;verticalAlign=top;fontStyle=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="545" y="170" width="300" height="300" as="geometry" />
        </mxCell>
        <mxCell id="nsConf" value="namespace: conflicts  (ethical wall)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E7F4E4;strokeColor=#6FA86A;verticalAlign=top;fontStyle=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="545" y="490" width="300" height="120" as="geometry" />
        </mxCell>

        <!-- ===================== HOST NODES ===================== -->
        <mxCell id="you" value="You" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="95" width="40" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cli" value="forgeos CLI&#10;(Rust binary)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="150" y="100" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="inproc" value="in-process agents&#10;(forgeos deploy runs them HERE,&#10;not in pods) — currently: none" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E0A030;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="195" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="api" value="Platform API  :5000&#10;(FastAPI + agent registry)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="300" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="driveTool" value="drive_tool — service-account&#10;impersonation (keyless, host ADC)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="70" y="420" width="300" height="55" as="geometry" />
        </mxCell>
        <mxCell id="kubectl" value="kubectl / scripts/local/lawfirm-check.sh&#10;(current workaround to reach a pod)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57C00;" vertex="1" parent="1">
          <mxGeometry x="70" y="540" width="300" height="55" as="geometry" />
        </mxCell>

        <!-- ===================== CLUSTER NODES ===================== -->
        <mxCell id="pulumi" value="Pulumi&#10;(pulumi up -s local)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;" vertex="1" parent="1">
          <mxGeometry x="960" y="95" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="assoc" value="law-firm-associate&#10;Deployment + Service&#10;(agent-base pod)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="565" y="200" width="255" height="60" as="geometry" />
        </mxCell>
        <mxCell id="risk" value="risk-compliance-auditor (pod)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="565" y="280" width="255" height="40" as="geometry" />
        </mxCell>
        <mxCell id="dock" value="docketing-clerk (pod)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="565" y="330" width="255" height="40" as="geometry" />
        </mxCell>
        <mxCell id="conf" value="conflicts-clerk&#10;Deployment + Service (pod)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="565" y="525" width="255" height="50" as="geometry" />
        </mxCell>
        <mxCell id="keda" value="KEDA&#10;ScaledObject" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#0097A7;" vertex="1" parent="1">
          <mxGeometry x="900" y="200" width="150" height="55" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="Redis queue&#10;agent:NAME (backlog)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="900" y="300" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- ===================== EXTERNAL SERVICES ===================== -->
        <mxCell id="gdrive" value="Google Drive&#10;(SA: forgeos-drive-agent)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#E8F0FE;strokeColor=#3367D6;" vertex="1" parent="1">
          <mxGeometry x="120" y="720" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="gemini" value="Gemini API&#10;(LLM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F4EA;strokeColor=#137333;" vertex="1" parent="1">
          <mxGeometry x="780" y="725" width="180" height="55" as="geometry" />
        </mxCell>

        <!-- ===================== EDGES ===================== -->
        <!-- working CLI path (blue) -->
        <mxCell id="e_you_cli" value="uses" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1976D2;" edge="1" parent="1" source="you" target="cli"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cli_api" value="HTTP :5000" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1976D2;fontColor=#1976D2;" edge="1" parent="1" source="cli" target="api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_api_inproc" value="forgeos invoke runs the agent IN-PROCESS here" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1976D2;fontColor=#1976D2;" edge="1" parent="1" source="api" target="inproc"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- the gap (red): platform has no route to the pods -->
        <mxCell id="e_api_pods_x" value="(was: no route — bridged by P1.7)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#BDBDBD;fontColor=#9E9E9E;dashed=1;dashPattern=8 8;endArrow=none;" edge="1" parent="1" source="api" target="assoc"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- current workaround (orange): hit the pod's Service directly -->
        <mxCell id="e_kubectl_assoc" value="POST /invoke&#10;(direct to pod Service)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#F57C00;fontColor=#E65100;strokeWidth=2;" edge="1" parent="1" source="kubectl" target="conf"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- proposed P1.7 (green dashed): platform forwards /invoke to the pod -->
        <mxCell id="e_p17" value="P1.7 ✓ DONE:&#10;Platform API forwards /invoke → pod&#10;(port-forward locally / Service DNS on GKE)&#10;so `forgeos invoke &lt;id&gt;` runs in the pod" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2E7D32;fontColor=#2E7D32;strokeWidth=3;exitX=1;exitY=0.25;entryX=0;entryY=0.75;" edge="1" parent="1" source="api" target="assoc"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Drive tool-proxy path (green): pod proxies tool calls back to platform -->
        <mxCell id="e_assoc_api" value="tool calls (drive__*)&#10;→ POST /api/sandbox/tool (+ scoped token)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#388E3C;fontColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="assoc" target="api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_api_drivetool" value="executes drive__*" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#388E3C;fontColor=#2E7D32;" edge="1" parent="1" source="api" target="driveTool"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_drivetool_gdrive" value="SA impersonation (keyless)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#388E3C;fontColor=#2E7D32;" edge="1" parent="1" source="driveTool" target="gdrive"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- LLM -->
        <mxCell id="e_assoc_gemini" value="LLM" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#137333;fontColor=#137333;" edge="1" parent="1" source="assoc" target="gemini"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- autoscale -->
        <mxCell id="e_redis_keda" value="backlog" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#C62828;fontColor=#C62828;" edge="1" parent="1" source="redis" target="keda"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_keda_assoc" value="scale 0..N" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#0097A7;fontColor=#00838F;" edge="1" parent="1" source="keda" target="assoc"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- provisioning -->
        <mxCell id="e_pulumi_legal" value="provisions" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#7E57C2;fontColor=#5E35B1;dashed=1;" edge="1" parent="1" source="pulumi" target="nsLegal"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_pulumi_conf" value="provisions" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#7E57C2;fontColor=#5E35B1;dashed=1;" edge="1" parent="1" source="pulumi" target="nsConf"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===================== LEGEND ===================== -->
        <mxCell id="legend" value="Legend&#10;━ blue: forgeos CLI → Platform API (→ in-process agent)&#10;━ green (thick): P1.7 ✓ CLI → platform → POD (/invoke forward)&#10;━ green: Drive proxy (pod → platform → SA → Google Drive)&#10;━ orange: alt path (kubectl/script direct to pod Service)&#10;┄ gray: (historical) no route — now bridged by P1.7&#10;━ teal/red: KEDA autoscale on Redis backlog&#10;┄ purple: Pulumi provisions the pods" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFFFFF;strokeColor=#BDBDBD;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="720" width="360" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
