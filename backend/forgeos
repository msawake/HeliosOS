API_BASE = "http://localhost:5000"


# ── API Client ──────────────────────────────────────────────────────────

def _api(method: str, path: str, body: dict | None = None, timeout: int = 120):
    url = f"{API_BASE}{path}"
    data = json.dumps(body).encode() if body else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err_body = e.read().decode() if e.fp else ""
        raise RuntimeError(f"API {e.code}: {err_body}") from e


def _api_healthy() -> bool:
    try:
        resp = _api("GET", "/api/health", timeout=3)
        return resp.get("status") in ("healthy", "ok")
    except Exception:
        return False


# ── Docker Compose ──────────────────────────────────────────────────────

def _docker_compose(*args, capture=False, stream=False):
    cmd = ["docker", "compose"] + list(args)
    if stream:
        proc = subprocess.Popen(cmd, cwd=_DOCKER_DIR)
        try:
            proc.wait()
        except KeyboardInterrupt:
            proc.terminate()
        return proc.returncode
    result = subprocess.run(cmd, cwd=_DOCKER_DIR, capture_output=capture, text=True)
    if capture:
        return result
    return result.returncode


# ── Agent Definition Persistence (YAML) ────────────────────────────────

def _load_custom_agents() -> list[dict]:
    agents = []
    if not os.path.isdir(_DEFINITIONS_DIR):
        return agents
    try:
        import yaml
    except ImportError:
        return agents
    for fname in sorted(os.listdir(_DEFINITIONS_DIR)):
        if not fname.endswith((".yaml", ".yml")):
            continue
        fpath = os.path.join(_DEFINITIONS_DIR, fname)
        try:
            with open(fpath) as f:
                spec = yaml.safe_load(f)
            if spec and isinstance(spec, dict) and "name" in spec:
                from stacks.base import ExecutionType, OwnershipType
                if isinstance(spec.get("execution_type"), str):
                    spec["execution_type"] = ExecutionType(spec["execution_type"])
                if isinstance(spec.get("ownership"), str):
                    spec["ownership"] = OwnershipType(spec["ownership"])
                elif "ownership" not in spec:
                    spec["ownership"] = OwnershipType.SHARED
                if "llm_config" not in spec:
                    spec["llm_config"] = {
                        "chat_model": spec.pop("chat_model", "gemini-2.5-flash"),
                        "reasoning_model": spec.pop("reasoning_model", None),
                        "provider": spec.pop("provider", "google"),
                    }
                spec.setdefault("stack", "forgeos")
                spec.setdefault("tools", [])
                spec.setdefault("metadata", {})
                spec.setdefault("description", "")
                spec.setdefault("system_prompt", "")
                spec["_source"] = "custom"
                spec["_file"] = fpath
                agents.append(spec)
        except Exception as e:
            print(f"  {RED}Warning: {fname}: {e}{RESET}")
    return agents


def _save_agent_yaml(spec: dict) -> str:
    import yaml
    os.makedirs(_DEFINITIONS_DIR, exist_ok=True)
    data = {}
    data["name"] = spec["name"]
    data["stack"] = spec.get("stack", "forgeos")
    etype = spec.get("execution_type")
    data["execution_type"] = etype.value if hasattr(etype, "value") else str(etype)
    ownership = spec.get("ownership")
    if ownership:
        data["ownership"] = ownership.value if hasattr(ownership, "value") else str(ownership)
    data["description"] = spec.get("description", "")
    data["department"] = spec.get("department", "")
    llm = spec.get("llm_config", {})
    data["chat_model"] = llm.get("chat_model", "gemini-2.5-flash")
    data["provider"] = llm.get("provider", "google")
    if llm.get("reasoning_model"):
        data["reasoning_model"] = llm["reasoning_model"]
    data["tools"] = spec.get("tools", [])
    data["metadata"] = spec.get("metadata", {})
    if spec.get("system_prompt"):
        data["system_prompt"] = spec["system_prompt"]
    if spec.get("schedule"):
        data["schedule"] = spec["schedule"]
    if spec.get("event_triggers"):
        data["event_triggers"] = spec["event_triggers"]
    fname = f"{spec['name']}.yaml"
    fpath = os.path.join(_DEFINITIONS_DIR, fname)
    with open(fpath, "w") as f:
        yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)
    return fpath


def _get_full_catalog() -> list[dict]:
    try:
        from src.platform.agent_definitions import ALL_AGENTS
        catalog = [dict(s, _source="builtin") for s in ALL_AGENTS]
    except Exception:
        catalog = []
    custom = _load_custom_agents()
    custom_names = {c["name"] for c in custom}
    merged = [s for s in catalog if s["name"] not in custom_names]
    merged.extend(custom)
    return merged


# ── .env Setup ──────────────────────────────────────────────────────────

def _ensure_env_file() -> bool:
    if os.path.isfile(_ENV_FILE):
        return True
    print(f"\n{BOLD}Docker environment setup{RESET}\n")
    db_password = secrets.token_hex(32)
    print(f"  {DIM}Enter API keys (press Enter to skip):{RESET}")
    try:
        anthropic_key = input(f"  Anthropic API key: ").strip()
        google_key = input(f"  Google API key: ").strip()
        openai_key = input(f"  OpenAI API key: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return False
    content = (
        f"# ForgeOS environment — generated by ./forgeos\n"
        f"DB_PASSWORD={db_password}\n"
        f"ANTHROPIC_API_KEY={anthropic_key}\n"
        f"GOOGLE_API_KEY={google_key}\n"
        f"OPENAI_API_KEY={openai_key}\n"
    )
    os.makedirs(os.path.dirname(_ENV_FILE), exist_ok=True)
    with open(_ENV_FILE, "w") as f:
        f.write(content)
    os.chmod(_ENV_FILE, 0o600)
    print(f"\n  {GREEN}✓ Environment file created{RESET}\n")
    return True


