            choice = input(f"{CYAN}Agents>{RESET} ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            break
        if choice in ("1", "list"):
            _agents_list()
        elif choice in ("2", "view"):
            _agents_view()
        elif choice in ("3", "create", "new"):
            _agents_create()
        elif choice in ("4", "edit"):
            _agents_edit()
        elif choice in ("5", "delete", "del"):
