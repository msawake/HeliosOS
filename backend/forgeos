def _do_agents():
    while True:
        print(f"\n{BOLD}Agents{RESET}\n")
        print(f"  {CYAN}1{RESET}  List definitions")
        print(f"  {CYAN}2{RESET}  View agent details")
        print(f"  {CYAN}3{RESET}  Create new agent")
        print(f"  {CYAN}4{RESET}  Edit custom agent")
        print(f"  {CYAN}5{RESET}  Delete custom agent")
