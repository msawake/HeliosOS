# Main Menu
# ═══════════════════════════════════════════════════════════════════════

def _print_banner():
    running = _api_healthy()
    env_str = f"{GREEN}running{RESET}" if running else f"{DIM}stopped{RESET}"
    print(f"""
{BOLD}╔══════════════════════════════════════════════════╗
║              ForgeOS CLI v4.0                    ║
╚══════════════════════════════════════════════════╝{RESET}
  Environment: {env_str}
""")


def _print_menu():
    print(f"{BOLD}What do you want to do?{RESET}")
    print()
    print(f"  {CYAN}1{RESET}  Agents        {DIM}list, create, edit definitions{RESET}")
    print(f"  {CYAN}2{RESET}  Environment   {DIM}start, stop, status, logs{RESET}")
    print(f"  {CYAN}3{RESET}  Deploy        {DIM}deploy agents to environment{RESET}")
    print(f"  {CYAN}4{RESET}  Chat          {DIM}talk to a deployed agent{RESET}")
    print(f"  {CYAN}5{RESET}  Monitor       {DIM}activity, workspace, live tail{RESET}")
    print(f"  {CYAN}q{RESET}  Quit")
    print()


def run_interactive():
    _print_banner()
    while True:
        _print_menu()
        try:
            choice = input(f"{CYAN}>{RESET} ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            break
        if choice in ("1", "agents"):
            _do_agents()
        elif choice in ("2", "env", "environment"):
            _do_environment()
        elif choice in ("3", "deploy"):
            _do_deploy()
        elif choice in ("4", "chat"):
            _do_chat()
        elif choice in ("5", "monitor"):
            _do_monitor()
        elif choice in ("q", "quit", "exit"):
            break
        else:
            print(f"{DIM}Pick 1-5 or q{RESET}")
        print()

    print("Goodbye!")


def main():
    parser = argparse.ArgumentParser(
        prog="forgeos",
        description="ForgeOS CLI — full lifecycle agent management",
    )
    parser.add_argument("--verbose", action="store_true", help="Show debug logs")
    parser.add_argument("--api-url", default=None, help="API URL (default: http://localhost:5000)")
    args = parser.parse_args()

    if args.api_url:
        global API_BASE
        API_BASE = args.api_url.rstrip("/")

    if not args.verbose:
        logging.disable(logging.CRITICAL)

    run_interactive()


if __name__ == "__main__":
    main()
