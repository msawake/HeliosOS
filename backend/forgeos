def _agents_list():
    catalog = _get_full_catalog()
    print(f"\n{BOLD}Agent Definitions ({len(catalog)}){RESET}\n")
    print(f"  {'#':<4} {'Name':<35} {'Stack':<10} {'Type':<14} {'Source'}")
    print(f"  {'─'*4} {'─'*35} {'─'*10} {'─'*14} {'─'*10}")
    for i, spec in enumerate(catalog, 1):
        name = spec["name"]
        stack = spec.get("stack", "?")
        etype = spec["execution_type"]
        etype_str = etype.value if hasattr(etype, "value") else str(etype)
        source = spec.get("_source", "?")
        source_str = f"{GREEN}custom{RESET}" if source == "custom" else f"{DIM}builtin{RESET}"
        print(f"  {i:<4} {name:<35} {stack:<10} {etype_str:<14} {source_str}")
    print()


def _agents_view():
    catalog = _get_full_catalog()
    if not catalog:
        print(f"\n  {DIM}No agent definitions.{RESET}\n")
        return
    _agents_list()
    try:
        raw = input(f"{CYAN}View #>{RESET} ").strip()
        idx = int(raw) - 1
        spec = catalog[idx]
    except (ValueError, IndexError, EOFError, KeyboardInterrupt):
        return

    name = spec["name"]
    etype = spec["execution_type"]
    etype_str = etype.value if hasattr(etype, "value") else str(etype)
    llm = spec.get("llm_config", {})
    meta = spec.get("metadata", {})

    print(f"\n{'─'*60}")
    print(f"{BOLD}{name}{RESET}")
    print(f"{'─'*60}")
    print(f"  Source:         {spec.get('_source', '?')}")
    print(f"  Stack:          {spec.get('stack', 'forgeos')}")
    print(f"  Type:           {etype_str}")
    print(f"  Department:     {spec.get('department') or '—'}")
    print(f"  Model:          {llm.get('chat_model', '?')} ({llm.get('provider', '?')})")
    print(f"  Tools:          {', '.join(spec.get('tools', [])) or '—'}")
    if meta.get("workspace"):
        print(f"  Workspace:      {meta['workspace']}")
    if meta.get("source_files"):
        print(f"  Source files:   {', '.join(meta['source_files'])}")
    if meta.get("loop_interval_seconds"):
        print(f"  Loop interval:  {meta['loop_interval_seconds']}s")
    print(f"  Description:    {spec.get('description', '')[:80]}")
    sp = spec.get("system_prompt", "")
    if sp:
        print(f"\n  {BOLD}System Prompt:{RESET}")
        for line in sp.split("\n")[:20]:
            print(f"  {DIM}{line}{RESET}")
        if sp.count("\n") > 20:
            print(f"  {DIM}... ({sp.count(chr(10)) - 20} more lines){RESET}")
    print()


def _agents_create():
    print(f"\n{BOLD}═══ Create New Agent ═══{RESET}\n")
    try:
        name = input(f"  Name: ").strip()
        if not name:
            print(f"  {RED}Name required.{RESET}")
            return
        name = name.lower().replace(" ", "-")

        description = input(f"  Description: ").strip()
        department = input(f"  Department [{DIM}general{RESET}]: ").strip() or "general"

        print(f"\n  {BOLD}LLM{RESET}")
        provider = input(f"  Provider (anthropic/google/openai) [{DIM}google{RESET}]: ").strip() or "google"
        defaults = {"google": "gemini-2.5-flash", "anthropic": "claude-sonnet-4-5-20250514", "openai": "gpt-4o"}
        default_model = defaults.get(provider, "gemini-2.5-flash")
        model = input(f"  Model [{DIM}{default_model}{RESET}]: ").strip() or default_model

        print(f"\n  {BOLD}Execution{RESET}")
        etype = input(f"  Type (always_on/event_driven/scheduled) [{DIM}always_on{RESET}]: ").strip() or "always_on"

        metadata = {}
        if etype == "always_on":
            interval = input(f"  Loop interval seconds [{DIM}120{RESET}]: ").strip()
            metadata["loop_interval_seconds"] = int(interval) if interval else 120

        print(f"\n  {BOLD}Tools{RESET}")
        print(f"  {DIM}Available: platform__file_read, platform__file_write, platform__file_list{RESET}")
        use_files = input(f"  Enable file tools? (y/n) [{DIM}y{RESET}]: ").strip().lower()
        tools = ["platform__file_read", "platform__file_write", "platform__file_list"] if use_files != "n" else []

        print(f"\n  {BOLD}Files{RESET}")
        default_ws = f"files/knowledge/{name}"
        workspace = input(f"  Workspace [{DIM}{default_ws}{RESET}]: ").strip() or default_ws
        metadata["workspace"] = workspace

        print(f"  Source files (one per line, empty to finish):")
        source_files = []
        while True:
            sf = input(f"    > ").strip()
            if not sf:
                break
            full_path = os.path.join(_REPO_ROOT, sf)
            if not os.path.isfile(full_path):
                print(f"    {YELLOW}⚠ {sf} not found locally — add it before building Docker{RESET}")
            source_files.append(sf)
        if source_files:
            metadata["source_files"] = source_files

        print(f"\n  {BOLD}System Prompt{RESET}")
        print(f"  {DIM}Enter prompt (end with a line containing only '---'):{RESET}")
        prompt_lines = []
        while True:
            line = input(f"  ")
            if line.strip() == "---":
                break
            prompt_lines.append(line)
        system_prompt = "\n".join(prompt_lines)

    except (EOFError, KeyboardInterrupt):
        print(f"\n  {DIM}Cancelled.{RESET}")
        return

    from stacks.base import ExecutionType, OwnershipType
    spec = {
        "name": name,
        "stack": "forgeos",
        "execution_type": ExecutionType(etype),
        "ownership": OwnershipType.SHARED,
        "description": description,
        "department": department,
        "llm_config": {"chat_model": model, "reasoning_model": None, "provider": provider},
        "tools": tools,
        "metadata": metadata,
        "system_prompt": system_prompt,
    }
    fpath = _save_agent_yaml(spec)
    print(f"\n  {GREEN}✓ Agent '{name}' saved to {fpath}{RESET}\n")


def _agents_edit():
    custom = [s for s in _get_full_catalog() if s.get("_source") == "custom"]
    if not custom:
        print(f"\n  {DIM}No custom agents. Create one first, or override a builtin by creating one with the same name.{RESET}\n")
        return

    print(f"\n{BOLD}Custom agents:{RESET}\n")
    for i, spec in enumerate(custom, 1):
        etype = spec["execution_type"]
        etype_str = etype.value if hasattr(etype, "value") else str(etype)
        print(f"  {i:<4} {spec['name']:<35} {etype_str}")

    try:
        raw = input(f"\n{CYAN}Edit #>{RESET} ").strip()
        idx = int(raw) - 1
        spec = custom[idx]
    except (ValueError, IndexError, EOFError, KeyboardInterrupt):
        return

    print(f"\n{BOLD}Editing: {spec['name']}{RESET}")
    print(f"{DIM}Press Enter to keep current value{RESET}\n")

    try:
        desc = input(f"  Description [{DIM}{spec.get('description','')[:50]}{RESET}]: ").strip()
        if desc:
            spec["description"] = desc

        dept = input(f"  Department [{DIM}{spec.get('department','')}{RESET}]: ").strip()
        if dept:
            spec["department"] = dept

        llm = spec.get("llm_config", {})
        prov = input(f"  Provider [{DIM}{llm.get('provider','')}{RESET}]: ").strip()
        if prov:
            llm["provider"] = prov

        model = input(f"  Model [{DIM}{llm.get('chat_model','')}{RESET}]: ").strip()
        if model:
            llm["chat_model"] = model

        meta = spec.get("metadata", {})
        if meta.get("loop_interval_seconds"):
            interval = input(f"  Loop interval [{DIM}{meta['loop_interval_seconds']}s{RESET}]: ").strip()
            if interval:
                meta["loop_interval_seconds"] = int(interval)

        sp = spec.get("system_prompt", "")
        if sp:
            print(f"\n  {DIM}Current prompt: {sp[:100]}...{RESET}")
        edit_prompt = input(f"  Edit system prompt? (y/n) [{DIM}n{RESET}]: ").strip().lower()
        if edit_prompt == "y":
            print(f"  {DIM}Enter new prompt (end with '---'):{RESET}")
            lines = []
            while True:
                line = input(f"  ")
                if line.strip() == "---":
                    break
                lines.append(line)
            spec["system_prompt"] = "\n".join(lines)

    except (EOFError, KeyboardInterrupt):
        print(f"\n  {DIM}Cancelled.{RESET}")
        return

    fpath = _save_agent_yaml(spec)
    print(f"\n  {GREEN}✓ Updated: {fpath}{RESET}\n")


def _agents_delete():
    custom = [s for s in _get_full_catalog() if s.get("_source") == "custom"]
    if not custom:
        print(f"\n  {DIM}No custom agents to delete.{RESET}\n")
        return

    print(f"\n{BOLD}Custom agents:{RESET}\n")
    for i, spec in enumerate(custom, 1):
        print(f"  {i:<4} {spec['name']}")

    try:
        raw = input(f"\n{CYAN}Delete #>{RESET} ").strip()
        idx = int(raw) - 1
        spec = custom[idx]
    except (ValueError, IndexError, EOFError, KeyboardInterrupt):
        return

    confirm = input(f"  Delete '{spec['name']}'? (yes/no): ").strip().lower()
    if confirm == "yes":
        fpath = spec.get("_file")
        if fpath and os.path.isfile(fpath):
            os.remove(fpath)
            print(f"  {GREEN}✓ Deleted{RESET}\n")
        else:
            print(f"  {RED}File not found.{RESET}\n")


