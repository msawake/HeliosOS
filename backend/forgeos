def _do_environment():
    while True:
        running = _api_healthy()
        status_str = f"{GREEN}running{RESET}" if running else f"{RED}stopped{RESET}"

        print(f"\n{BOLD}Environment{RESET}  [{status_str}]\n")
        print(f"  {CYAN}1{RESET}  Start        {DIM}build & launch containers{RESET}")
        print(f"  {CYAN}2{RESET}  Stop         {DIM}tear down containers{RESET}")
        print(f"  {CYAN}3{RESET}  Status       {DIM}containers + health check{RESET}")
        print(f"  {CYAN}4{RESET}  Logs         {DIM}stream container logs{RESET}")
        print(f"  {CYAN}5{RESET}  Rebuild      {DIM}force rebuild image & restart{RESET}")
        print(f"  {CYAN}b{RESET}  Back")
        print()
        try:
            choice = input(f"{CYAN}Env>{RESET} ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            break
        if choice in ("1", "start"):
            _env_start()
        elif choice in ("2", "stop"):
            _env_stop()
        elif choice in ("3", "status"):
            _env_status()
        elif choice in ("4", "logs"):
            _env_logs()
        elif choice in ("5", "rebuild"):
            _env_start(rebuild=True)
        elif choice in ("b", "back"):
            break


def _env_start(rebuild=False):
    if not _ensure_env_file():
        return
    action = "Rebuilding" if rebuild else "Starting"
    print(f"\n{DIM}{action} ForgeOS environment...{RESET}\n")

    args = ["up", "-d"]
    if rebuild:
        args.insert(1, "--build")

    rc = _docker_compose(*args)
    if rc != 0:
        print(f"\n{RED}Failed. Is Docker installed and running?{RESET}\n")
        return

    print(f"\n{DIM}Waiting for API...{RESET}", end="", flush=True)
    for _ in range(60):
        time.sleep(2)
        if _api_healthy():
            print(f" {GREEN}ready!{RESET}\n")
            return
        print(".", end="", flush=True)
    print(f" {YELLOW}timeout — check 'Logs' for details{RESET}\n")


def _env_stop():
    print(f"\n{DIM}Stopping environment...{RESET}")
    _docker_compose("down")
    print(f"{GREEN}Stopped.{RESET}\n")


def _env_status():
    print()
    result = _docker_compose("ps", "--format", "table {{.Name}}\t{{.Status}}\t{{.Ports}}", capture=True)
    if result.stdout.strip():
        print(result.stdout)
    else:
        print(f"  {DIM}No containers running.{RESET}")

    if _api_healthy():
        print(f"  API: {GREEN}healthy{RESET}")
        try:
            health = _api("GET", "/api/health")
            for k, v in health.get("components", {}).items():
                st = v if isinstance(v, str) else v.get("status", str(v))
                color = GREEN if st in ("ok", "healthy", "connected") else YELLOW
                print(f"    {k}: {color}{st}{RESET}")
        except Exception:
            pass
        try:
            agents = _api("GET", "/api/platform/agents")
            print(f"  Agents deployed: {BOLD}{len(agents)}{RESET}")
        except Exception:
            pass
    else:
        print(f"  API: {RED}unreachable{RESET}")
    print()


def _env_logs():
    print(f"\n{DIM}Streaming logs... (Ctrl+C to stop){RESET}\n")
    _docker_compose("logs", "-f", "--tail", "100", "forgeos", stream=True)
    print()


# ═══════════════════════════════════════════════════════════════════════
# 3. Deploy — send agents to running environment
# ═══════════════════════════════════════════════════════════════════════

def _do_deploy():
    if not _api_healthy():
        print(f"\n{RED}Environment not running. Start it first (option 2).{RESET}\n")
        return

    catalog = _get_full_catalog()
    try:
        agents = _api("GET", "/api/platform/agents")
    except Exception as e:
        print(f"\n{RED}API error: {e}{RESET}\n")
        return
    deployed_names = {a["name"] for a in agents}

    available = [(i, s) for i, s in enumerate(catalog, 1) if s["name"] not in deployed_names]
    if not available:
        print(f"\n{DIM}All agents already deployed ({len(agents)} running).{RESET}\n")
        return

    print(f"\n{BOLD}Available to deploy ({len(available)}/{len(catalog)}):{RESET}\n")
    for i, spec in available:
        etype = spec["execution_type"]
        etype_str = etype.value if hasattr(etype, "value") else str(etype)
        star = f" {GREEN}★{RESET}" if spec.get("_source") == "custom" else ""
        print(f"  {i:<4} {spec['name']:<35} ({spec.get('stack','?')}/{etype_str}){star}")

    print(f"\n  {DIM}Enter numbers, range (1-5), or 'all'{RESET}")
    try:
        raw = input(f"\n{CYAN}Deploy>{RESET} ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return
    if not raw:
        return

    indices = set()
    if raw.lower() == "all":
        indices = {i for i, _ in available}
    else:
        for part in raw.replace(",", " ").split():
            if "-" in part:
                lo, hi = part.split("-", 1)
                try:
                    indices.update(range(int(lo), int(hi) + 1))
                except ValueError:
                    pass
            else:
                try:
                    indices.add(int(part))
                except ValueError:
                    pass

    to_deploy = [s for i, s in available if i in indices]
    if not to_deploy:
        print(f"{DIM}No valid selection.{RESET}")
        return

    print()
    for spec in to_deploy:
        name = spec["name"]
        llm = spec.get("llm_config", {})
        etype = spec["execution_type"]
        etype_str = etype.value if hasattr(etype, "value") else str(etype)
        ownership = spec.get("ownership", "shared")
        if hasattr(ownership, "value"):
            ownership = ownership.value

        body = {
            "name": name,
            "stack": spec.get("stack", "forgeos"),
            "execution_type": etype_str,
            "ownership": str(ownership),
            "department": spec.get("department", ""),
            "description": spec.get("description", ""),
            "goal": spec.get("goal", ""),
            "tools": spec.get("tools", []),
            "metadata": spec.get("metadata", {}),
            "chat_model": llm.get("chat_model", "gemini-2.5-flash"),
            "provider": llm.get("provider", "google"),
            "system_prompt": spec.get("system_prompt", ""),
        }
        if spec.get("schedule"):
            body["schedule"] = spec["schedule"]
        if spec.get("event_triggers"):
            body["event_triggers"] = spec["event_triggers"]

        try:
            resp = _api("POST", "/api/platform/agents", body)
            agent_id = resp.get("agent_id", "?")
            print(f"  {GREEN}✓{RESET} {name} ({agent_id}) — {etype_str}")
        except Exception as e:
            print(f"  {RED}✗{RESET} {name}: {e}")
    print()


# ═══════════════════════════════════════════════════════════════════════
# 4. Chat — interactive conversation with deployed agent
# ═══════════════════════════════════════════════════════════════════════

def _do_chat():
    if not _api_healthy():
        print(f"\n{RED}Environment not running. Start it first (option 2).{RESET}\n")
        return

    try:
        agents = _api("GET", "/api/platform/agents")
    except Exception as e:
        print(f"\n{RED}API error: {e}{RESET}\n")
        return
    if not agents:
        print(f"\n{DIM}No deployed agents. Deploy some first (option 3).{RESET}\n")
        return

    print(f"\n{BOLD}Deployed agents:{RESET}\n")
    for i, a in enumerate(agents, 1):
        name = a.get("name", "?")
        etype = a.get("execution_type", "?")
        print(f"  {i:<4} {name:<35} {DIM}{etype}{RESET}")

    try:
        raw = input(f"\n{CYAN}Chat with #>{RESET} ").strip()
        idx = int(raw) - 1
        agent = agents[idx]
    except (ValueError, IndexError, EOFError, KeyboardInterrupt):
        print()
        return

    agent_id = agent["agent_id"]
    name = agent.get("name", agent_id)

    print(f"\n{BOLD}Chatting with {name}{RESET}")
    print(f"{DIM}Type 'back' to return{RESET}\n")

    while True:
        try:
            user_input = input(f"{CYAN}You>{RESET} ")
        except (EOFError, KeyboardInterrupt):
            print()
            break
        cmd = user_input.strip().lower()
        if cmd in ("back", "quit", "exit", "q"):
            break
        if not user_input.strip():
            continue
        try:
            print(f"{DIM}Thinking...{RESET}", end="", flush=True)
            resp = _api("POST", f"/api/platform/agents/{agent_id}/invoke",
                        {"prompt": user_input}, timeout=300)
            print(f"\r{' '*20}\r", end="")
            error = resp.get("error")
            output = resp.get("result", "")
            tokens = resp.get("tokens_used", 0)
            tool_calls = resp.get("tool_calls", 0)
            if error:
                print(f"{YELLOW}{name}>{RESET} {RED}[Error]{RESET} {error}\n")
            else:
                print(f"{YELLOW}{name}>{RESET} {output or '(no response)'}")
                if tokens or tool_calls:
                    print(f"{DIM}  [{tokens} tokens, {tool_calls} tool calls]{RESET}")
                print()
        except Exception as e:
            print(f"\r{' '*20}\r", end="")
            print(f"{YELLOW}{name}>{RESET} {RED}[Error]{RESET} {e}\n")
    print()


# ═══════════════════════════════════════════════════════════════════════
# 5. Monitor — activity logs, workspace files, live tail
# ═══════════════════════════════════════════════════════════════════════

def _do_monitor():
    if not _api_healthy():
        print(f"\n{RED}Environment not running. Start it first (option 2).{RESET}\n")
        return

    try:
        agents = _api("GET", "/api/platform/agents")
    except Exception as e:
        print(f"\n{RED}API error: {e}{RESET}\n")
        return
    if not agents:
        print(f"\n{DIM}No deployed agents.{RESET}\n")
        return

    print(f"\n{BOLD}Deployed agents:{RESET}\n")
    for i, a in enumerate(agents, 1):
        name = a.get("name", "?")
        etype = a.get("execution_type", "?")
        print(f"  {i:<4} {name:<35} {etype}")

    try:
        raw = input(f"\n{CYAN}Monitor #>{RESET} ").strip()
        idx = int(raw) - 1
        agent = agents[idx]
    except (ValueError, IndexError, EOFError, KeyboardInterrupt):
        print()
        return

    agent_id = agent["agent_id"]
    name = agent.get("name", agent_id)

    _show_agent_info(agent)
    _show_workspace(agent_id)
    _show_activity(agent_id)

    print(f"\n{DIM}Commands: tail | refresh | files | read <filename> | back{RESET}")
    while True:
        try:
            cmd = input(f"{CYAN}Monitor:{name}>{RESET} ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break
        parts = cmd.lower().split(None, 1)
        if not parts:
            continue
        verb = parts[0]
        arg = parts[1] if len(parts) > 1 else ""

        if verb in ("back", "b", "q", "quit"):
            break
        elif verb == "tail":
            _monitor_tail(agent_id, name)
        elif verb in ("refresh", "r"):
            _show_workspace(agent_id)
            _show_activity(agent_id)
        elif verb == "files":
            _show_workspace(agent_id)
        elif verb == "read" and arg:
            _read_workspace_file(agent_id, arg)
        elif verb == "read":
            print(f"  {DIM}Usage: read <filename>{RESET}")
        elif verb == "info":
            _show_agent_info(agent)
        else:
            print(f"  {DIM}Commands: tail | refresh | files | read <filename> | back{RESET}")
    print()


def _show_agent_info(agent: dict):
    agent_id = agent["agent_id"]
    name = agent.get("name", agent_id)
    llm = agent.get("llm_config", {})
    meta = agent.get("metadata", {})

    print(f"\n{'─'*60}")
    print(f"{BOLD}{name}{RESET}")
    print(f"{'─'*60}")
    print(f"  Agent ID:       {agent_id}")
    print(f"  Stack:          {agent.get('stack', '?')}")
    print(f"  Type:           {agent.get('execution_type', '?')}")
    print(f"  Department:     {agent.get('department') or '—'}")
    if isinstance(llm, dict):
        print(f"  Model:          {llm.get('chat_model', '?')} ({llm.get('provider', '?')})")
    tools = agent.get("tools", [])
    print(f"  Tools:          {', '.join(tools) if tools else '—'}")
    if meta.get("workspace"):
        print(f"  Workspace:      {meta['workspace']}")
    if meta.get("source_files"):
        print(f"  Source files:   {', '.join(meta['source_files'])}")
    if meta.get("loop_interval_seconds"):
        print(f"  Loop interval:  {meta['loop_interval_seconds']}s")
    desc = agent.get("description", "")
    if desc:
        print(f"  Description:    {desc[:80]}")


def _show_workspace(agent_id: str):
    try:
        ws = _api("GET", f"/api/platform/agents/{agent_id}/workspace")
        files = ws.get("files", [])
        if files:
            print(f"\n  {BOLD}Workspace files:{RESET}")
            for f in files:
                print(f"    {f['name']:<40} {f['size']:>8} bytes")
        elif ws.get("workspace"):
            print(f"\n  {DIM}Workspace empty (agent hasn't produced files yet){RESET}")
    except Exception:
        pass


def _show_activity(agent_id: str):
    try:
        act = _api("GET", f"/api/platform/agents/{agent_id}/activity?limit=50")
        log = act.get("entries", [])
        if log:
            _print_activity_log(log)
        else:
            print(f"\n  {DIM}No activity yet.{RESET}")
    except Exception:
        pass


def _read_workspace_file(agent_id: str, filename: str):
    try:
        resp = _api("GET", f"/api/platform/agents/{agent_id}/workspace/{filename}")
        content = resp.get("content", "")
        size = resp.get("size", 0)
        print(f"\n  {BOLD}{filename}{RESET} ({size} bytes)\n")
        for line in content.split("\n"):
            print(f"  {line}")
        print()
    except Exception as e:
        print(f"  {RED}Error: {e}{RESET}\n")


def _monitor_tail(agent_id: str, name: str):
    print(f"\n{DIM}Live tail for {name}... (Ctrl+C to stop){RESET}\n")
    try:
        act = _api("GET", f"/api/platform/agents/{agent_id}/activity?limit=9999")
        seen = len(act.get("entries", []))
    except Exception:
        seen = 0
    try:
        while True:
            time.sleep(2)
            try:
                act = _api("GET", f"/api/platform/agents/{agent_id}/activity?limit=9999")
                full_log = act.get("entries", [])
                for entry in full_log[seen:]:
                    _print_activity_entry(entry)
                seen = len(full_log)
            except Exception:
                pass
    except KeyboardInterrupt:
        pass
    print()


# ── Activity log formatting ────────────────────────────────────────────

def _print_activity_log(log: list[dict]):
    print(f"\n  {BOLD}Activity log ({len(log)} entries):{RESET}\n")
    for entry in log:
        _print_activity_entry(entry)


def _print_activity_entry(entry: dict):
    ts = entry.get("timestamp", "")
    ts_short = ts[11:19] if len(ts) > 19 else ts
    etype = entry.get("type", "?")

    if etype == "loop_start":
        print(f"  {DIM}{ts_short}{RESET}  {GREEN}▶ Loop started{RESET} (interval: {entry.get('interval')}s)")
    elif etype == "loop_tick":
        print(f"  {DIM}{ts_short}{RESET}  ↻ Iteration #{entry.get('iteration')}")
    elif etype == "invoke":
        prompt = entry.get("prompt", "")
        if prompt.startswith("Standing duties"):
            print(f"  {DIM}{ts_short}{RESET}  ⚙ Standing duties")
        else:
            print(f"  {DIM}{ts_short}{RESET}  💬 {prompt[:80]}")
    elif etype == "tool_call":
        tool = entry.get("tool", "?")
        inp = entry.get("input", {})
        detail = inp.get("path", inp.get("directory", ""))
        print(f"  {DIM}{ts_short}{RESET}  🔧 {tool}" + (f" → {detail}" if detail else ""))
    elif etype == "result":
        st = entry.get("status", "?")
        tokens = entry.get("tokens", 0)
        err = entry.get("error")
        if err:
            print(f"  {DIM}{ts_short}{RESET}  {RED}✗ {st}: {err}{RESET}")
        else:
            preview = (entry.get("output_preview") or "")[:100].replace("\n", " ")
            tok_str = f"({tokens} tok)"
            print(f"  {DIM}{ts_short}{RESET}  {GREEN}✓{RESET} {st} {tok_str}" + (f" — {DIM}{preview}{RESET}" if preview else ""))
    elif etype == "loop_error":
        print(f"  {DIM}{ts_short}{RESET}  {RED}✗ {entry.get('error', '?')}{RESET}")
    elif etype == "stopped":
        print(f"  {DIM}{ts_short}{RESET}  {RED}■ Stopped{RESET}")
    else:
        print(f"  {DIM}{ts_short}{RESET}  {etype}")


