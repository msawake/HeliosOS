FROM python:3.12-slim AS sandbox

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir httpx anthropic openai pyyaml

COPY src/forgeos_sandbox/ /app/src/forgeos_sandbox/
COPY src/forgeos_sdk/client.py /app/src/forgeos_sdk/client.py
COPY src/forgeos_sdk/__init__.py /app/src/forgeos_sdk/__init__.py

RUN groupadd -g 1000 sandbox && useradd -u 1000 -g sandbox -m sandbox
USER 1000
WORKDIR /app
ENV PYTHONPATH=/app PYTHONUNBUFFERED=1

CMD ["python", "-m", "src.forgeos_sandbox.runner"]
